[Unit]
Description=Modem manager (Huawei MU509 - power, PPP internet, AT control)
After=network.target
StartLimitIntervalSec=0

[Service]
# Run as a normal user, not root - just needs group membership for the
# serial ports (dialout), pppd (dip), and GPIO (gpio). See README "Modem
# daemon setup" for the exact `usermod` commands.
User=root
WorkingDirectory=/root/sms-gateway
ExecStart=/root/sms-gateway/venv/bin/python3 /root/sms-gateway/run_modem_manager.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
